# Multi-agent environment configuration
# Generated by Ansible — do not edit manually

# Base path
PATH_BACKEND_CONFIG="{{ path_backend_config | trim }}"

# Per-profile paths
{% for service in cp_waf_agent_multi_services %}
PATH_CP_AGENT_WAF_CERTS_{{ service.profile_name | upper }}="{{ path_backend_config }}/Certs/{{ service.profile_name }}"
PATH_CP_AGENT_WAF_CONFIGURATION_{{ service.profile_name | upper }}="{{ path_backend_config }}/AgentConfiguration/{{ service.profile_name }}"
PATH_CP_NGINX_CONFIGURATION_{{ service.profile_name | upper }}="{{ path_backend_config }}/NginxConfiguration/{{ service.profile_name }}"
PATH_CP_AGENT_WAF_DATA_{{ service.profile_name | upper }}="{{ path_backend_config }}/Data/{{ service.profile_name }}"
PATH_CP_AGENT_WAF_LOGS_{{ service.profile_name | upper }}="{{ path_backend_config }}/Logs/{{ service.profile_name }}"
{% endfor %}

# Container images (per image family)
{% for image in cp_waf_agent_multi_images %}
CP_WAF_AGENT_IMG_{{ image.family_name | upper }}="{{ image.registry_url | default(docker_registry_url) }}/{{  image.registry_folder | default(docker_registry_folder) }}/{{ image.cp_agent_image | default(docker_cp_agent_image) }}"
{% endfor %}

# Resource limits (per profile)
{% for resource in cp_waf_agent_multi_resources %}
DOCKER_MAIN_CP_WAF_AGENT_CPU_{{ resource.profile_name | upper }}="{{ resource.cpu | default('2.6') }}"
DOCKER_MAIN_CP_WAF_AGENT_MEM_{{ resource.profile_name | upper }}="{{ resource.mem | default('1GB') }}"
{% endfor %}
