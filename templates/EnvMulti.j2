# Multi-agent environment configuration
# Generated by Ansible — do not edit manually

# Base path
PATH_BACKEND_CONFIG="{{ path_backend_config | trim }}"

# Per-profile paths
{% for volume in cp_waf_agent_multi_volumes %}
PATH_CP_AGENT_WAF_CERTS_{{ volume.profile_name | upper }}="{{ path_backend_config }}/Certs/{{ volume.profile_name }}"
PATH_CP_AGENT_WAF_CONFIGURATION_{{ volume.profile_name | upper }}="{{ path_backend_config }}/AgentConfiguration/{{ volume.profile_name }}"
PATH_CP_NGINX_CONFIGURATION_{{ volume.profile_name | upper }}="{{ path_backend_config }}/NginxConfiguration/{{ volume.profile_name }}"
PATH_CP_AGENT_WAF_DATA_{{ volume.profile_name | upper }}="{{ path_backend_config }}/Data/{{ volume.profile_name }}"
PATH_CP_AGENT_WAF_LOGS_{{ volume.profile_name | upper }}="{{ path_backend_config }}/Logs/{{ volume.profile_name }}"
{% endfor %}

# Container images (per image family)
{% for image in cp_waf_agent_multi_images %}
CP_WAF_AGENT_IMG_{{ image.family_name | upper }}="{{ docker_registry_url }}/{{ docker_registry_folder }}/{{ docker_cp_agent_image }}"
{% endfor %}

# Resource limits (per profile)
{% for resource in cp_waf_agent_multi_resources %}
DOCKER_MAIN_CP_WAF_AGENT_CPU_{{ resource.profile_name | upper }}="{{ resource.cpu | default('2.6') }}"
DOCKER_MAIN_CP_WAF_AGENT_MEM_{{ resource.profile_name | upper }}="{{ resource.mem | default('1GB') }}"
{% endfor %}
